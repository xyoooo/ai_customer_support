SUPPORTPILOT_ENVIRONMENT=development
SUPPORTPILOT_DATABASE_URL=postgresql+asyncpg://supportpilot_app:local_app_password@localhost:5432/supportpilot
SUPPORTPILOT_MIGRATION_DATABASE_URL=postgresql+psycopg://supportpilot_migrator:local_migrator_password@localhost:5432/supportpilot
SUPPORTPILOT_JWT_SECRET=replace-with-at-least-32-random-characters
SUPPORTPILOT_ALLOWED_ORIGINS=["http://localhost:5173"]
SUPPORTPILOT_SECURE_COOKIES=false
SUPPORTPILOT_OBJECT_STORE_ROOT=var/objects
SUPPORTPILOT_MAX_UPLOAD_BYTES=10485760
SUPPORTPILOT_MAX_WORKSPACE_STORAGE_BYTES=104857600
SUPPORTPILOT_ALLOW_NOOP_MALWARE_SCANNER=true
